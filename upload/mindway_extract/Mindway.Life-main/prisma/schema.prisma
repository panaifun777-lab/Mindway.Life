generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Philosopher {
  id           String @id @default(cuid())
  nameCn       String
  nameEn       String
  slug         String @unique
  era          String // 古典/近代/当代/主理人
  category     String // 情绪类/关系类/选择类/意义类/综合类
  avatarUrl    String @default("")
  tagline      String
  bioSummary   String
  coreInsight  String
  worries      String // comma-separated worry tags
  works           String // comma-separated works
  recommendedBooks String  @default("") // JSON string: [{title, author, reason}]
  quote           String
  quoteSource   String @default("")
  description   String @default("")  // 详细介绍（全文）
  systemPrompt String
  order        Int    @default(0)
  isHost       Boolean @default(false) // 主理人标识
  published    Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id            String   @id @default(cuid())
  philosopherId String
  mode          String   @default("single") // single / debate
  philosopherId2 String?  // for debate mode
  userId        String?  // optional: link to user
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  philosopher  Philosopher @relation(fields: [philosopherId], references: [id])
  messages     Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user / assistant / philosopher1 / philosopher2
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  avatar         String   @default("")
  plan           String   @default("free") // free / pro / premium
  stripeCustomerId String @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions Subscription[]

  @@map("users")
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  plan            String   // free / pro / premium
  amount          Int      @default(0) // price in cents (RMB fen)
  currency        String   @default("CNY")
  interval        String   @default("month") // month / year
  status          String   @default("active") // active / cancelled / expired
  startDate       DateTime @default(now())
  endDate         DateTime?
  paymentMethod   String   @default("") // stripe / wechat / alipay
  transactionId   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
