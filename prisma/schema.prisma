generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Philosopher {
  id           String @id @default(cuid())
  nameCn       String
  nameEn       String
  slug         String @unique
  era          String // 古典/近代/当代/主理人
  category     String // 情绪类/关系类/选择类/意义类/综合类
  avatarUrl    String @default("")
  tagline      String
  bioSummary   String
  coreInsight  String
  worries      String // comma-separated worry tags
  works           String // comma-separated works
  recommendedBooks String  @default("") // JSON string: [{title, author, reason}]
  quote           String
  quoteSource   String @default("")
  description   String @default("")  // 详细介绍（全文）
  systemPrompt String
  order        Int    @default(0)
  isHost       Boolean @default(false) // 主理人标识
  published    Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id            String   @id @default(cuid())
  philosopherId String
  mode          String   @default("single") // single / debate
  philosopherId2 String?  // for debate mode
  userId        String?  // optional: link to user
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  philosopher  Philosopher @relation(fields: [philosopherId], references: [id])
  messages     Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user / assistant / philosopher1 / philosopher2
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  avatar         String   @default("")
  plan           String   @default("free") // free / pro / premium
  role           String   @default("user") // user / admin
  stripeCustomerId String @default("")
  referralCode   String   @default("")
  referredBy     String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions Subscription[]
  insights      UserInsight[]

  @@map("users")
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  plan            String   // free / pro / premium
  amount          Int      @default(0) // price in cents (RMB fen)
  currency        String   @default("CNY")
  interval        String   @default("month") // month / year
  status          String   @default("active") // active / cancelled / expired
  startDate       DateTime @default(now())
  endDate         DateTime?
  paymentMethod   String   @default("") // stripe / wechat / alipay
  transactionId   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UserInsight {
  id                      String   @id @default(cuid())
  userId                  String
  corePain                String   @default("") // 核心痛点
  cognitiveBlindSpots     String   @default("") // 认知盲区
  valueTendency           String   @default("") // 价值观倾向
  communicationPreference String   @default("") // 沟通偏好
  emotionBaseline         String   @default("平静") // 情绪基线
  insightSummary          String   @default("") // 洞察摘要(JSON字符串)
  conversationCount       Int      @default(0) // 对话次数
  lastAnalyzedAt          DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_insights")
}

model CrisisLog {
  id                   String   @id @default(cuid())
  userId               String?  // 可为空，未登录用户也记录
  userInput            String   // 触发熔断的用户输入
  riskLevel            String   // safe / mild / severe
  triggerKeywords      String   @default("") // 触发的敏感词(JSON数组)
  interventionResponse String   // 熔断回复内容
  hotlineShown         Boolean  @default(false) // 是否展示了热线
  resolved             Boolean  @default(false) // 是否已处理
  createdAt            DateTime @default(now())

  @@map("crisis_logs")
}

// ===== 运营管理相关模型 =====

model SiteConfig {
  id          String   @id @default("default")
  siteName    String   @default("Mindway.Life")
  announcement String  @default("") // 公告
  bannerText  String   @default("") // Banner文字
  bannerEnabled Boolean @default(false)
  contactEmail String  @default("piaoshu@mindway.life")
  llmProvider String   @default("zhipu") // zhipu / deepseek / zai
  zhipuApiKey String   @default("")
  deepseekApiKey String @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique // 优惠码
  discountType String  // percentage / fixed
  discountValue Int    // 百分比(如30=30%) 或 固定金额(分)
  planId      String   @default("") // 适用套餐，空=全部
  maxUses     Int      @default(100) // 最大使用次数
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("coupons")
}

model UserFavorite {
  id            String   @id @default(cuid())
  userId        String
  philosopherId String
  createdAt     DateTime @default(now())

  @@unique([userId, philosopherId])
  @@map("user_favorites")
}

model ConversationRating {
  id            String   @id @default(cuid())
  userId        String?
  conversationId String
  rating        Int      // 1-5 星
  feedback      String   @default("")
  createdAt     DateTime @default(now())

  @@map("conversation_ratings")
}

// ===== 盈利模型 =====

model TokenAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  balance         Int      @default(100)
  totalPurchased  Int      @default(0)
  totalConsumed   Int      @default(0)
  monthlyResetAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("token_accounts")
}

model TokenTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Int
  balance     Int
  description String   @default("")
  createdAt   DateTime @default(now())

  @@map("token_transactions")
}

model Article {
  id            String   @id @default(cuid())
  authorId      String
  philosopherId String?
  title         String
  summary       String   @default("")
  content       String   @default("")
  coverImage    String   @default("")
  price         Int      @default(0)
  category      String   @default("philosophy")
  tags          String   @default("")
  published     Boolean  @default(true)
  viewCount     Int      @default(0)
  likeCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("articles")
}

model ArticlePurchase {
  id          String   @id @default(cuid())
  userId      String
  articleId   String
  price       Int
  createdAt   DateTime @default(now())

  @@unique([userId, articleId])
  @@map("article_purchases")
}

model DigitalLife {
  id                String   @id @default(cuid())
  userId            String   @unique
  name              String
  description       String   @default("")
  personality       String   @default("")
  knowledgeBase     String   @default("")
  systemPrompt      String   @default("")
  avatar            String   @default("")
  tier              String   @default("basic")
  conversationCount Int      @default(0)
  maxConversations  Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("digital_lives")
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  referralCode String
  commission   Int      @default(0)
  status       String   @default("registered")
  createdAt    DateTime @default(now())
  paidAt       DateTime?

  @@map("referrals")
}
